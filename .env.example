# === PostgreSQL (docker-compose) ===
DB_USER=clinica
DB_PASS=clinica
DB_NAME=clinica_gestion

# === ms-gestion (Spring Boot) ===
DB_URL=jdbc:postgresql://localhost:5432/clinica_gestion
SUPABASE_JWKS_URI=https://<tu-proyecto>.supabase.co/auth/v1/.well-known/jwks.json
BLOCKCHAIN_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:4200
SPRING_PROFILES_ACTIVE=dev

# === ms-blockchain (Node) ===
PORT=3001
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
PRIVATE_KEY=0x<tu_private_key_de_wallet_con_matic_de_amoy>
CONTRACT_ADDRESS=
POLYGONSCAN_API_KEY=
# Mismo JWKS que Spring para validar tokens Supabase

# === Angular (apps/web-angular/.env o environment.ts) ===
ANGULAR_SUPABASE_URL=https://<tu-proyecto>.supabase.co
ANGULAR_SUPABASE_ANON_KEY=<anon-key-de-supabase>
ANGULAR_GRAPHQL_URL=http://localhost:8080/graphql
ANGULAR_BLOCKCHAIN_URL=http://localhost:3001
