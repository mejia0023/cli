# ============================================================================
# .env.example — Template para configuracion local
# Copia este archivo como `.env` (esta en .gitignore) y rellena tus valores.
# ============================================================================

# === PostgreSQL ===
# Si usas el Postgres del docker-compose:        DB_USER=clinica DB_PASS=clinica
# Si usas un Postgres nativo instalado en tu OS: DB_USER=postgres DB_PASS=<tu_password>
DB_USER=<your_db_user>
DB_PASS=<your_db_password>
DB_NAME=ms_gestion

# === ms-gestion (Spring Boot) ===
DB_URL=jdbc:postgresql://localhost:5432/ms_gestion
SPRING_PROFILES_ACTIVE=dev
BLOCKCHAIN_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:4200

# Auth Supabase. Si esta vacio, ms-gestion corre en modo DEV sin auth (permitAll).
# Para activar JWT: setea con la URL JWKS de tu proyecto Supabase.
SUPABASE_JWKS_URI=
# Ejemplo: SUPABASE_JWKS_URI=https://<your-project>.supabase.co/auth/v1/.well-known/jwks.json

# === ms-blockchain (Node) ===
PORT=3001
# Para desarrollo local con Hardhat node:
#   AMOY_RPC_URL=http://127.0.0.1:8545
#   PRIVATE_KEY=<usa una cuenta de hardhat node, ver salida al ejecutar `npx hardhat node`>
# Para deploy a Polygon Amoy testnet:
#   AMOY_RPC_URL=https://rpc-amoy.polygon.technology
#   PRIVATE_KEY=<tu private key de wallet con MATIC del faucet>
AMOY_RPC_URL=<your_rpc_url>
PRIVATE_KEY=<your_private_key>
CONTRACT_ADDRESS=<deployed_contract_address>
POLYGONSCAN_API_KEY=<optional_for_verify>

# === Angular (web-angular) ===
# Estos NO se leen desde aqui (Angular usa src/environments/environment.ts).
# Listados solo como referencia de los valores que necesitas tener configurados ahi.
# ANGULAR_SUPABASE_URL=https://<your-project>.supabase.co
# ANGULAR_SUPABASE_ANON_KEY=<sb_publishable_...>
