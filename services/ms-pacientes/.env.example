# ============================================================================
# .env.example — MS1 ms-pacientes (Next.js + Prisma)
# Copia como .env y rellena. Esta en .gitignore.
# ============================================================================

# PostgreSQL local nativo (la base ms_pacientes ya existe en :5432)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ms_pacientes"

# Supabase Auth (MISMO proyecto que ms-gestion -> identidad compartida)
SUPABASE_JWKS_URI=https://<tu-proyecto>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_ISSUER=https://<tu-proyecto>.supabase.co/auth/v1

# Clave service_role (Dashboard -> Project Settings -> API -> service_role).
# SOLO va en este backend, NUNCA en el frontend. La usa el ADMINISTRADOR para
# crear usuarios (cuenta de login + rol) desde la pantalla Administracion.
SUPABASE_SERVICE_ROLE_KEY=

# Puerto local
PORT=3000
