# === Servidor Express ===
PORT=3001
CORS_ORIGINS=http://localhost:4200,http://localhost:8080

# === Auth Supabase (mismo proyecto que ms-gestion) ===
# Si esta vacio, ms-blockchain corre en modo DEV sin auth (NO en prod)
SUPABASE_JWKS_URI=https://<tu-proyecto>.supabase.co/auth/v1/.well-known/jwks.json

# === Polygon Amoy ===
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
PRIVATE_KEY=0x<tu_private_key_de_wallet_con_matic_de_amoy_faucet>
CONTRACT_ADDRESS=0x<address_devuelto_por_deploy.js>

# === Verificacion en explorer (opcional) ===
POLYGONSCAN_API_KEY=
