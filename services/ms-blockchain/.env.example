# ============================================================================
# .env.example — Template para ms-blockchain
# Copia este archivo como `.env` (esta en .gitignore) y rellena tus valores.
# ============================================================================

# === Servidor Express ===
PORT=3001
CORS_ORIGINS=http://localhost:4200,http://localhost:8080

# === Auth Supabase (mismo proyecto que ms-gestion) ===
# Si esta vacio, ms-blockchain corre en modo DEV sin auth (NO usar en prod).
SUPABASE_JWKS_URI=

# === Red blockchain ===
# Para desarrollo local con `npx hardhat node`:
#   AMOY_RPC_URL=http://127.0.0.1:8545
#   PRIVATE_KEY=<copiar la primera cuenta que imprime hardhat node al arrancar>
#
# Para deploy a Polygon Amoy testnet:
#   AMOY_RPC_URL=https://rpc-amoy.polygon.technology
#   PRIVATE_KEY=<tu private key de wallet con >= 0.5 MATIC del faucet>
AMOY_RPC_URL=<your_rpc_url>
PRIVATE_KEY=<your_private_key>
CONTRACT_ADDRESS=<deployed_contract_address>

# === Verificacion en explorer (opcional) ===
POLYGONSCAN_API_KEY=
