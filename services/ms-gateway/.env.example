# ============================================================================
# .env.example — ms-gateway (schema stitching MS1 + MS3)
# ============================================================================

# Endpoints GraphQL de los subgrafos
MS1_URL=http://localhost:3000/api/graphql
MS3_URL=http://localhost:8080/graphql

# SDL de MS3 (su /graphql esta protegido, no se puede introspeccionar sin token):
# se leen los .graphqls del repo. Por defecto apunta al monorepo.
MS3_SDL_DIR=../ms-gestion/src/main/resources/graphql

# Puerto del gateway
PORT=4000
