# ============================================================================
# .env.example — MS2 ms-diagnosticos (Django/DRF + IA + documental)
# ============================================================================

# Django
DJANGO_SECRET_KEY=dev-insecure-cambia-esto
DJANGO_DEBUG=true

# Supabase Auth (MISMO proyecto que MS1/MS3 -> identidad compartida)
SUPABASE_JWKS_URI=https://<tu-proyecto>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_ISSUER=https://<tu-proyecto>.supabase.co/auth/v1

# Almacenamiento. USE_AWS=false -> fallback local (filesystem + JSON), corre sin AWS.
# USE_AWS=true -> S3 nativo (con versioning) + DynamoDB (requiere credenciales AWS).
USE_AWS=false
AWS_REGION=us-east-1
S3_BUCKET=c..6
AWS_ACCESS_KEY_ID=AK..Y
AWS_SECRET_ACCESS_KEY=f..S
DDB_PREFIX=

# DynamoDB LOCAL (emulador, sin cuenta AWS): levantar `docker compose up -d dynamodb-local`,
# crear tablas con `DDB_ENDPOINT_URL=http://localhost:8001 python plan/ms2-diagnosticos-tables.py`
# y descomentar la linea de abajo. Los archivos siguen en disco local.
 DDB_ENDPOINT_URL=http://localhost:8001

# Blockchain (ms-blockchain). Si esta caido, el anclaje degrada (no rompe).
BLOCKCHAIN_URL=http://localhost:3001
BLOCKCHAIN_ENABLED=true

# MS1 (ms-pacientes) GraphQL: a donde MS2 avisa que un resultado esta listo
# (mutation notificarResultado -> push #3). Si MS1 esta caido, el diagnostico
# se guarda igual y solo se loggea un warning.
MS1_GRAPHQL_URL=http://localhost:3000/api/graphql

# Puerto
PORT=8000
