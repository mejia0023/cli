# ============================================================================
# .gitignore — Clinica monorepo
# Repo PUBLICO listo para deploy en la nube: ningun archivo con secretos
# debe estar versionado. Si encuentras uno, agregalo aqui.
# ============================================================================


# ====== SECRETOS Y CREDENCIALES (nunca commitear) ======
.env
.env.*
!.env.example
!.env.template
*.env
*.secret
*.secrets
secrets/
secrets.*
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
credentials.*
credenciales.*
c.c
**/local.config.*
*.local.json

# Angular: environment con credenciales reales (usa fileReplacement en dev)
**/environments/environment.local.ts

# Archivos de notas locales del usuario
notes.txt
NOTAS.md
TODO.local.*

# Tokens y exports de servicios
**/service-account*.json
firebase-adminsdk*.json
auth-token*.txt


# ====== JAVA / MAVEN ======
target/
*.class
*.jar
*.war
*.ear
*.log
hs_err_pid*
.mvn/wrapper/maven-wrapper.jar


# ====== NODE ======
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/


# ====== ANGULAR ======
dist/
.angular/
*.tsbuildinfo


# ====== HARDHAT / SOLIDITY ======
artifacts/
cache/
typechain/
typechain-types/
deployments/


# ====== EDITORES / IDEs ======
.vscode/
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.iml
*.ipr
*.iws
*.swp
*~
.DS_Store
Thumbs.db


# ====== SISTEMA OPERATIVO ======
*.bak
*.tmp


# ====== DOCKER ======
*.pid


# ====== OUTPUT BUILD ======
build/
out/
coverage/
.nyc_output/


# ====== MISC LOCAL ======
*.local
t.t
*.draft.*
.scratch/
infra/
docs/
.claude
suba.pase
howItwork.block

